*{box-sizing:border-box}body{margin:0;background:#07100d;color:#eef7f2;font-family:Tahoma,Arial}header{height:78px;padding:0 4%;display:flex;align-items:center;justify-content:space-between;background:#0a1410;border-bottom:1px solid #21362d;position:sticky;top:0}.brand,.status{display:flex;align-items:center;gap:12px}.logo{width:44px;height:44px;border:1px solid #19d17f;border-radius:12px;display:grid;place-items:center;color:#19d17f;font-size:23px;font-weight:900}h1,h2{margin:0}.brand h1{font-size:20px}small{color:#8ca095}.status span{width:10px;height:10px;background:#19d17f;border-radius:50%;box-shadow:0 0 13px #19d17f}main{width:min(1450px,94%);margin:20px auto}.summary,.grid{display:grid;gap:14px}.summary{grid-template-columns:repeat(4,1fr)}.top{grid-template-columns:1.3fr 1fr 1fr;margin-top:14px}.scores{grid-template-columns:repeat(4,1fr);margin-top:14px}.content{grid-template-columns:1.55fr 1fr;margin-top:14px}.card,.metric{background:linear-gradient(#101d17,#0b1511);border:1px solid #21362d;border-radius:15px;padding:17px}.metric b{font-size:22px;display:block;margin-top:7px}.head{display:flex;justify-content:space-between}.ring{width:64px;height:64px;border:6px solid #19d17f;border-left-color:#24372f;border-radius:50%;display:grid;place-items:center;font-size:20px;font-weight:900}.ticker{display:flex;justify-content:space-between;align-items:center;margin:18px 0}.ticker strong{font-size:30px}.ticker span{display:block}.ticker em{font-style:normal;padding:7px 10px;border-radius:999px;background:#123e2f;color:#19d17f;font-weight:800}.reason,.block{padding:10px;background:#08120e;border:1px solid #1d3329;border-radius:9px;margin-top:8px}.reason b{float:left;color:#19d17f}.big{display:flex;justify-content:space-between;align-items:end;margin:20px 0}.big b{font-size:32px;color:#19d17f}.bar{height:10px;background:#203029;border-radius:99px;overflow:hidden}.bar i{display:block;height:100%;background:#19d17f}.zones,.plan{display:grid;gap:8px;margin-top:15px}.zones div,.plan div{background:#08120e;border:1px solid #1d3329;padding:10px;border-radius:9px}.zones b,.plan b{display:block;margin-top:5px}table{width:100%;border-collapse:collapse;min-width:760px}.table-wrap{overflow:auto;margin-top:12px}th,td{text-align:right;padding:12px;border-bottom:1px solid #1d3028}th{color:#8ca095;font-size:12px}tbody tr{cursor:pointer}.pill{padding:6px 8px;border-radius:999px;font-weight:800;font-size:12px}.buy{background:#113d2d;color:#19d17f}.watch{background:#413713;color:#f4c655}.sell{background:#491c28;color:#ff6376}.neutral{background:#26332d;color:#c5d0ca}button{background:#16432f;color:#fff;border:1px solid #277750;border-radius:9px;padding:9px 14px;font-weight:800}hr{border:0;border-top:1px solid #21362d;margin:20px 0}.note{text-align:center;color:#8ca095;font-size:12px;padding:20px}#toast{position:fixed;bottom:20px;left:20px;background:#133b2b;border:1px solid #25744e;padding:12px 16px;border-radius:10px;display:none}@media(max-width:1000px){.top,.content{grid-template-columns:1fr}.summary,.scores{grid-template-columns:1fr 1fr}}@media(max-width:580px){.summary,.scores{grid-template-columns:1fr}.status{display:none}}